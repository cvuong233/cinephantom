<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="CinePhantom"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CinePhantom">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CinePhantom">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEARCH" />
            </intent-filter>
            <meta-data
                android:name="android.app.searchable"
                android:resource="@xml/searchable" />
        </activity>

        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="true"
            android:theme="@style/Theme.CinePhantom">
        </activity>

        <activity
            android:name=".ui.detail.DetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.detail.FullCastActivity"
            android:exported="false" />

        <activity
            android:name=".ui.detail.CastDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.account.AuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.account.WishlistActivity"
            android:exported="false" />

        <activity
            android:name=".notifications.NotificationSettingsActivity"
            android:exported="false" />

        <!-- Small widget: search bar only -->
        <receiver
            android:name=".widget.ImdbSearchWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_small" />
        </receiver>

        <!-- Big widget: featured item + search -->
        <receiver
            android:name=".widget.ImdbSearchWidgetBigProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_big" />
        </receiver>

        <receiver
            android:name=".widget.WidgetRefreshReceiver"
            android:exported="false" />

        <receiver
            android:name=".notifications.WishlistNotificationReceiver"
            android:exported="false" />
    </application>

</manifest>
