<?xml version="1.0" encoding="utf-8"?>
<!-- TEST E: TEST C + ONE element: divider View with background.
     If this fails → View/divider is the problem.
     If this works → I add the next element. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FF0A0F1E"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_rank_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#3 Movie"
        android:textColor="#FF6B7CFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="The Shawshank Redemption"
        android:textColor="#FFF5F7FF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- ONE new element: divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#FF24304C" />

</LinearLayout>
