<?xml version="1.0" encoding="utf-8"?>
<!-- DIAGNOSTIC STEP 2: Same green layout, but with android:id on the main text.
     onUpdate() will change this text. If user sees the changed text, the update path works. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FF00C853"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_debug_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BIG WIDGET"
        android:textColor="#FFFFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_debug_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="TEST MODE"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp" />

</LinearLayout>
