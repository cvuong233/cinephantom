<?xml version="1.0" encoding="utf-8"?>
<!-- FINAL V2: Hero poster fills featured area. Rank badge overlaid bottom-right.
     FrameLayout for overlay (supported in RemoteViews). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0A0F1E">

    <!-- Featured area: poster fills space, rank overlaid -->
    <FrameLayout
        android:id="@+id/widget_featured"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Hero poster (centerCrop fills the area) -->
        <ImageView
            android:id="@+id/widget_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#FF0D1526" />

        <!-- Rank badge: bottom-right, semitransparent -->
        <TextView
            android:id="@+id/widget_rank_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:background="#CC000000"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="#FFF5F7FF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Divider (TextView, not View) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF24304C" />

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/widget_search_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="C"
            android:textColor="#FF6B7CFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:text="Search movies and shows"
            android:textColor="#FF7C8AAF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_search_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search"
            android:textColor="#FF6B7CFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
