<?xml version="1.0" encoding="utf-8"?>
<!-- TEST C: EXACT same structure as green diagnostic (flat, 2 TextView, no nesting).
     Different: dark root bg, more text fields, below divider + search bar.
     If this fails, the issue is colors/attributes. If it works, nesting causes the break. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FF0A0F1E"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_rank_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#3 Movie"
        android:textColor="#FF6B7CFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="The Shawshank Redemption"
        android:textColor="#FFF5F7FF"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>
