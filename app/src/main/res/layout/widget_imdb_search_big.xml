<?xml version="1.0" encoding="utf-8"?>
<!-- TEST F: TEST C + divider as TextView (height=1dp, background).
     Testing if TextView divider works vs View divider. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FF0A0F1E"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_rank_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#3 Movie"
        android:textColor="#FF6B7CFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="The Shawshank Redemption"
        android:textColor="#FFF5F7FF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Divider as TextView (height=1dp, background color) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#FF24304C" />

</LinearLayout>
