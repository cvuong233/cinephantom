<?xml version="1.0" encoding="utf-8"?>
<!-- ULTRA-SIMPLE debug layout — no poster frame, no weights, no gradients -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A237E"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_debug_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CinePhantom BIG"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#FFFFFFFF" />

    <TextView
        android:id="@+id/widget_rank_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="#1 DEBUG MOVIE"
        android:textColor="#FFFFEB3B"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Debug Title v53"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="IMDb 9.3"
        android:textColor="#FFFF9800"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="2026"
        android:textColor="#FF90CAF9"
        android:textSize="12sp" />

    <!-- Search pill row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="#FF283593"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Search movies &amp; shows"
            android:textColor="#FF90CAF9"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
