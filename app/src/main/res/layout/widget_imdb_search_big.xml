<?xml version="1.0" encoding="utf-8"?>
<!-- Hero poster widget: poster fills featured area, rank overlaid bottom-right, search bar below. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0A0F1E">

    <!-- Featured area: poster fills space, rank overlaid -->
    <FrameLayout
        android:id="@+id/widget_featured"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Hero poster (centerCrop fills the area) -->
        <ImageView
            android:id="@+id/widget_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#FF0D1526" />

        <!-- Rank badge: bottom-right, semitransparent -->
        <TextView
            android:id="@+id/widget_rank_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="#CC000000"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#FFF5F7FF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF24304C" />

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/widget_search_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FF10182E">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_search"
            android:contentDescription="Search" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Search movies and shows"
            android:textColor="#FF7C8AAF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
