<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0F1E">

    <ImageView
        android:id="@+id/widget_poster"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#FF0D1526" />

    <FrameLayout
        android:id="@+id/widget_featured"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000" />

    <FrameLayout
        android:id="@+id/widget_search_bar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/widget_search_fab_bg"
        android:padding="16dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Search"
            android:src="@drawable/ic_widget_search" />
    </FrameLayout>
</RelativeLayout>
