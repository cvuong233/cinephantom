<?xml version="1.0" encoding="utf-8"?>
<!-- Home screen widget: featured item card + search bar -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_search_background"
    android:clickable="true"
    android:focusable="true"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Featured item card -->
        <FrameLayout
            android:id="@+id/widget_featured_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0DF5F7FF"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Poster or placeholder -->
                <FrameLayout
                    android:id="@+id/widget_poster_frame"
                    android:layout_width="70dp"
                    android:layout_height="100dp"
                    android:background="@drawable/widget_preview_placeholder"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/widget_poster"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/widget_poster_label"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🎬"
                        android:textSize="28sp"
                        android:visibility="visible" />
                </FrameLayout>

                <!-- Text info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Rank badge -->
                    <TextView
                        android:id="@+id/widget_rank_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#1AFFA723"
                        android:paddingLeft="8dp"
                        android:paddingTop="2dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="2dp"
                        android:text="Movie"
                        android:textColor="#FFA723"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <!-- Title -->
                    <TextView
                        android:id="@+id/widget_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="#F5F7FF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- IMDb rating -->
                    <TextView
                        android:id="@+id/widget_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="#FFA723"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- Year -->
                    <TextView
                        android:id="@+id/widget_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#6B7280"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Loading indicator (hidden when loaded) -->
            <TextView
                android:id="@+id/widget_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Loading..."
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:visibility="visible" />
        </FrameLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF" />

        <!-- Search bar section -->
        <FrameLayout
            android:id="@+id/widget_search_section"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#0DF5F7FF"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/widget_brand_dot"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="C"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/widget_hint"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#1A6B7CFF"
                    android:gravity="center"
                    android:paddingLeft="10dp"
                    android:paddingTop="4dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="4dp"
                    android:text="Search"
                    android:textColor="#6B7CFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
