<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/screen_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/discover_title"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/discover_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/discover_updated_placeholder"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/discover_filter_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_discover_tab_bar"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/discover_filter_movies"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_discover_tab_selected"
            android:clickable="true"
            android:drawablePadding="8dp"
            android:drawableStart="@drawable/ic_tab_movies"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="Movies"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/discover_filter_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_discover_tab_unselected"
            android:clickable="true"
            android:drawablePadding="8dp"
            android:drawableStart="@drawable/ic_tab_tv"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="TV Shows"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/discover_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="80dp" />

    <TextView
        android:id="@+id/discover_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="40dp"
        android:text="@string/discover_error"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
