<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════════
             SIGNED-OUT STATE
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/account_signed_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_account"
                android:alpha="0.20"
                android:contentDescription="@null"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_tv_stats_card"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CinePhantom Account"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Sign in to sync your watchlist"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/account_sign_in_btn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_rating_pill"
                    android:gravity="center"
                    android:text="Sign in"
                    android:textColor="@color/secondary_link"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════
             SIGNED-IN STATE
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/account_signed_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ── Decorative gradient banner ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="@drawable/bg_account_hero_gradient" />

            <!-- ── Content area (overlaps the gradient) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-36dp"
                android:paddingHorizontal="20dp"
                android:paddingBottom="40dp">

                <!-- ── Screen header: title + sign-out ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Account"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/account_sign_out_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tv_stats_card"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Sign out"
                        android:textColor="#FF6B6B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- ── Profile card ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_tv_stats_card"
                    android:padding="18dp">

                    <!-- Avatar with purple ring -->
                    <TextView
                        android:id="@+id/account_avatar"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_account_avatar"
                        android:gravity="center"
                        android:textColor="@color/secondary_link"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/account_display_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/account_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/account_provider_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="9dp"
                            android:background="@drawable/bg_tv_stats_card"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/secondary_accent"
                            android:textSize="11sp"
                            android:letterSpacing="0.04" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Purple accent divider ── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/secondary_accent_dim" />

                <!-- ── Section label ── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="6dp"
                    android:text="LIBRARY"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <!-- ── Menu card ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tv_stats_card">

                    <!-- Watchlist row -->
                    <LinearLayout
                        android:id="@+id/account_watchlist_row"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_heart_filled"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Watchlist"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/account_watchlist_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tv_stats_card"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:textColor="@color/secondary_link"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="›"
                            android:textColor="@color/text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <!-- Divider between rows -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/secondary_accent_dim" android:layout_marginHorizontal="16dp" />

                    <!-- Notification Settings row -->
                    <LinearLayout
                        android:id="@+id/account_notif_settings_row"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_notification_watchlist"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Notification Settings"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <!-- Divider between rows -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/secondary_accent_dim" android:layout_marginHorizontal="16dp" />

                    <!-- Notification History row -->
                    <LinearLayout
                        android:id="@+id/account_notif_history_row"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_history"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Notification History"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                    <!-- Divider between rows -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/secondary_accent_dim" android:layout_marginHorizontal="16dp" />

                    <!-- Streaming Platforms row -->
                    <LinearLayout
                        android:id="@+id/account_streaming_platforms_row"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_tab_tv"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Streaming Platforms"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/text_muted"
                            android:textSize="22sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
