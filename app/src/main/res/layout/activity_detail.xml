<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO SECTION -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <com.cvuong233.cinephantom.ui.search.ShimmerView
                android:id="@+id/hero_skeleton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/detail_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0D1526"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/detail_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <!-- Title skeleton -->
            <com.cvuong233.cinephantom.ui.search.ShimmerView
                android:id="@+id/title_skeleton"
                android:layout_width="260dp"
                android:layout_height="22dp"
                android:visibility="visible" />

            <!-- Real title -->
            <TextView
                android:id="@+id/detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Meta+rating skeleton -->
            <com.cvuong233.cinephantom.ui.search.ShimmerView
                android:id="@+id/meta_skeleton"
                android:layout_width="180dp"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:visibility="visible" />

            <!-- Real meta row -->
            <TextView
                android:id="@+id/detail_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Real IMDb rating -->
            <TextView
                android:id="@+id/detail_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/widget_imdb"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Genre skeleton -->
            <com.cvuong233.cinephantom.ui.search.ShimmerView
                android:id="@+id/genre_skeleton"
                android:layout_width="200dp"
                android:layout_height="28dp"
                android:layout_marginTop="10dp"
                android:visibility="visible" />

            <!-- Real genres -->
            <com.cvuong233.cinephantom.ui.detail.FlowLayout
                android:id="@+id/detail_genres_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone" />

            <!-- Director skeleton -->
            <com.cvuong233.cinephantom.ui.search.ShimmerView
                android:id="@+id/director_skeleton"
                android:layout_width="150dp"
                android:layout_height="13dp"
                android:layout_marginTop="12dp"
                android:visibility="visible" />

            <!-- Real director -->
            <TextView
                android:id="@+id/detail_director"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#24304C" />

            <!-- Description skeleton: 3 stacked shimmer lines -->
            <LinearLayout
                android:id="@+id/desc_skeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="visible">

                <com.cvuong233.cinephantom.ui.search.ShimmerView
                    android:layout_width="match_parent"
                    android:layout_height="14dp" />

                <com.cvuong233.cinephantom.ui.search.ShimmerView
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    android:layout_marginTop="8dp" />

                <com.cvuong233.cinephantom.ui.search.ShimmerView
                    android:layout_width="200dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- About label -->
            <TextView
                android:id="@+id/detail_about_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="About"
                android:textAllCaps="true"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Real description -->
            <TextView
                android:id="@+id/detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Cast skeleton: 4 groups (circle + bar) -->
            <LinearLayout
                android:id="@+id/cast_skeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingTop="4dp">

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="52dp"
                        android:layout_height="52dp" />

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="60dp"
                        android:layout_height="11dp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingTop="4dp">

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="52dp"
                        android:layout_height="52dp" />

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="60dp"
                        android:layout_height="11dp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingTop="4dp">

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="52dp"
                        android:layout_height="52dp" />

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="60dp"
                        android:layout_height="11dp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:paddingTop="4dp">

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="52dp"
                        android:layout_height="52dp" />

                    <com.cvuong233.cinephantom.ui.search.ShimmerView
                        android:layout_width="60dp"
                        android:layout_height="11dp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Cast label -->
            <TextView
                android:id="@+id/detail_cast_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Cast"
                android:textAllCaps="true"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Real cast horizontal scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/detail_cast_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Stremio button (always visible) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/detail_stremio_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/stremio_open_button"
                android:textAllCaps="false"
                android:textColor="@color/electric_blue"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_stremio_icon"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:strokeColor="@color/electric_blue"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/surface_raised" />
        </LinearLayout>

        <!-- Bottom spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>
