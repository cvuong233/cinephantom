<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detail_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="370dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/detail_backdrop"
                android:layout_width="match_parent"
                android:layout_height="196dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:transitionName="backdrop_transition"
                android:alpha="0" />

            <View
                android:layout_width="match_parent"
                android:layout_height="196dp"
                android:background="@drawable/gradient_hero_fade" />

            <LinearLayout
                android:id="@+id/detail_hero_shimmer"
                android:layout_width="match_parent"
                android:layout_height="196dp"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/detail_shimmer_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_search"
                    android:alpha="0.15"
                    android:contentDescription="@null" />

                <View
                    android:id="@+id/detail_shimmer_bar"
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/text_muted"
                    android:alpha="0.2" />
            </LinearLayout>

            <ImageView
                android:id="@+id/detail_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="12dp"
                android:alpha="0"
                android:background="@drawable/bg_back_button"
                android:clickable="true"
                android:contentDescription="Back"
                android:focusable="true"
                android:padding="9dp"
                android:src="@drawable/ic_back" />

            <ImageView
                android:id="@+id/detail_favorite_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="60dp"
                android:background="@drawable/bg_back_button"
                android:clickable="true"
                android:contentDescription="Add to Watchlist"
                android:elevation="12dp"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_heart_outline" />

            <ImageView
                android:id="@+id/detail_share_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_back_button"
                android:clickable="true"
                android:contentDescription="@string/share_title"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_share" />

            <LinearLayout
                android:id="@+id/detail_poster_container"
                android:layout_width="126dp"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="20dp"
                android:layout_marginTop="122dp"
                android:orientation="vertical"
                android:elevation="16dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="189dp"
                    android:background="@drawable/bg_glass_card"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/detail_hero"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop" />
                </FrameLayout>

                <TextView
                    android:id="@+id/detail_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_rating_pill"
                    android:gravity="center"
                    android:minHeight="28dp"
                    android:paddingLeft="10dp"
                    android:paddingTop="4dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/widget_imdb"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="160dp"
                android:layout_marginTop="206dp"
                android:layout_marginEnd="20dp"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/detail_title_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:maxLines="3"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/detail_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:id="@+id/detail_streaming_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingVertical="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <ImageView
                            android:id="@+id/detail_stremio_button"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_back_button"
                            android:contentDescription="@string/stremio_open_button"
                            android:elevation="12dp"
                            android:padding="8dp"
                            android:src="@drawable/ic_stremio_brand" />

                        <LinearLayout
                            android:id="@+id/detail_providers_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:clipChildren="false"
                            android:clipToPadding="false"
                            android:orientation="horizontal" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="0dp">

            <TextView
                android:id="@+id/detail_trailer_button"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <com.cvuong233.cinephantom.ui.detail.FlowLayout
                android:id="@+id/detail_genres_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone" />

            <View
                android:id="@+id/detail_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:background="@color/widget_divider"
                android:visibility="gone" />

            <TextView
                android:id="@+id/detail_about_label"
                style="@style/LabelSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="About"
                android:visibility="gone" />

            <TextView
                android:id="@+id/detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.02"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/detail_director_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/detail_director_label"
                    style="@style/LabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Director" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/detail_director_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/detail_director_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Movie release date card — mutually exclusive with next episode card -->
            <LinearLayout
                android:id="@+id/detail_movie_release_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_tv_stats_card"
                android:clipToOutline="true"
                android:outlineProvider="background"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/secondary_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/detail_movie_release_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="RELEASE DATE"
                        android:textColor="@color/secondary_link"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_movie_release_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Next episode card — shown below stats card for returning series only -->
            <LinearLayout
                android:id="@+id/detail_next_episode_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_tv_stats_card"
                android:clipToOutline="true"
                android:outlineProvider="background"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/secondary_accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:letterSpacing="0.1"
                            android:text="NEXT EPISODE"
                            android:textColor="@color/secondary_link"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/detail_next_episode_code"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/secondary_link"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/detail_next_episode_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_next_episode_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/detail_cast_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/detail_cast_label"
                    style="@style/LabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cast" />

                <TextView
                    android:id="@+id/detail_cast_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textColor="@color/secondary_link"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/detail_cast_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/detail_cast_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ── More Like This ── -->
        <LinearLayout
            android:id="@+id/detail_more_like_this_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="More Like This" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/detail_recommendations_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="6dp" />

            </HorizontalScrollView>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
